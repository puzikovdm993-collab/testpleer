```gitignore
# Compiled Python files
*.pyc
__pycache__/

# Virtual environments
venv/
.venv/
env/

# Logs
*.log

# Environment variables
.env
.env.local
*.env.*

# Editor/IDE files
.vscode/
.idea/
*.swp
*.swo
*.tmp

# Coverage reports
.coverage
coverage/
htmlcov/

# Python cache
.mypy_cache/
.pytest_cache/

# Build artifacts
dist/
build/
target/
```